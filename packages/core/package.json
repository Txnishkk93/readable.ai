{
  "name": "@readable-ai/core",
  "version": "0.1.0-alpha",
  "description": "Parser engine for converting LLM responses into structured data",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8.0.0",
    "typescript": "5.7.3",
    "vitest": "^1.0.0"
  }
}